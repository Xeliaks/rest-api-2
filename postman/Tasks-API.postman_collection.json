{
  "info": {
    "name": "Tasks API",
    "description": "Postman collection for the Spring Boot Tasks API (in-memory JSON CRUD + HAL hypermedia).\n\n**Setup**\n1. Start the app: `mvn spring-boot:run`\n2. Run **Create task** under **Tasks** — it saves `taskId` from the response.\n3. Optionally set `baseUrl`, `page`, and `pageSize` on the collection.\n\n**Folders**\n- **Tasks** — plain JSON at `/api/tasks`\n- **Tasks (hypermedia)** — HAL at `/api/hypermedia/tasks` (pagination + `_links`)\n- **OpenAPI** — raw OpenAPI 3 JSON\n\nOpenAPI: `{{baseUrl}}/v3/api-docs` · Swagger UI: `{{baseUrl}}/swagger-ui.html`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "taskId",
      "value": ""
    },
    {
      "key": "page",
      "value": "0"
    },
    {
      "key": "pageSize",
      "value": "10"
    }
  ],
  "item": [
    {
      "name": "Tasks",
      "description": "Classic REST JSON under `/api/tasks`.",
      "item": [
        {
          "name": "List tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tasks",
            "description": "Returns all tasks as a JSON array (may be empty)."
          }
        },
        {
          "name": "Get task by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "description": "Uses collection variable `taskId` (set by **Create task** or paste a UUID)."
          }
        },
        {
          "name": "Create task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    if (body && body.id) {",
                  "        pm.collectionVariables.set('taskId', body.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, bread, eggs\",\n  \"completed\": false\n}"
            },
            "url": "{{baseUrl}}/api/tasks",
            "description": "Creates a task. On success, saves returned `id` into collection variable `taskId`."
          }
        },
        {
          "name": "Replace task (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy organic groceries\",\n  \"description\": \"Updated list\",\n  \"completed\": true\n}"
            },
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "description": "Full replacement; `title` and `completed` are required."
          }
        },
        {
          "name": "Patch task",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"completed\": false\n}"
            },
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "description": "Partial update; include only fields to change."
          }
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "description": "204 No Content on success."
          }
        }
      ]
    },
    {
      "name": "Tasks (hypermedia)",
      "description": "HAL responses: `_links`, paged `_embedded.tasks`, and `page` metadata.",
      "item": [
        {
          "name": "List tasks (paged HAL)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/hal+json"
              }
            ],
            "url": "{{baseUrl}}/api/hypermedia/tasks?page={{page}}&size={{pageSize}}",
            "description": "Returns a HAL paged document: `_embedded.tasks`, `page` (size, number, totalElements, totalPages), and `_links` (`self`, `first`, `last`, `next`, `prev` when applicable). Each embedded task includes its own `_links`."
          }
        },
        {
          "name": "Get task by id (HAL)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/hal+json"
              }
            ],
            "url": "{{baseUrl}}/api/hypermedia/tasks/{{taskId}}",
            "description": "Single task with `_links.self`, `_links.collection`, and `_links.alternate` pointing at the plain JSON resource `/api/tasks/{id}`."
          }
        }
      ]
    },
    {
      "name": "OpenAPI",
      "item": [
        {
          "name": "Get OpenAPI document (JSON)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v3/api-docs",
            "description": "OpenAPI 3 JSON used by Swagger UI."
          }
        }
      ]
    }
  ]
}
